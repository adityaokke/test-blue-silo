// .vscode/launch.json

{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev: ts-node-dev",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
